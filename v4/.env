# Aviation Girl V4 Discord Bot Environment Configuration
# Copy this file to .env and fill in your values

# Discord Configuration
AVIATION_BOT_DISCORD_TOKEN=MTMyMTc4ODcxNTczMDk5NzMzOQ.GAVnCx.aOv0tQEJrTsiopauXJFOrlKHYQ_PWfMGWHkJ3c
AVIATION_BOT_DISCORD_PREFIX=!
AVIATION_BOT_DISCORD_STATUS=Flying high! ✈️

# AI Model Configuration
AVIATION_BOT_AI_MODEL=qwen2.5
AVIATION_BOT_AI_MODEL_PATH=
AVIATION_BOT_AI_TEMPERATURE=0.7

# API Keys
AVIATION_BOT_WEATHER_API_KEY=your_weather_api_key_here
AVIATION_BOT_FLIGHT_API_KEY=your_flight_tracking_api_key_here
