# Deployment Configuration
AVIATION_BOT_ENVIRONMENT=development
AVIATION_BOT_DEBUG=true
AVIATION_BOT_CONTAINER_MODE=false

# Monitoring Configuration
AVIATION_BOT_LOG_LEVEL=INFO
AVIATION_BOT_METRICS_PORT=8080

# Security (for production)
