# Aviation Girl V4 Discord Bot - Development Dockerfile
FROM python:3.11-slim

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV AVIATION_BOT_ENVIRONMENT=development
ENV AVIATION_BOT_DEBUG=true

# Install system dependencies including development tools
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    curl \
    git \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Set work directory
WORKDIR /app

# Copy requirements first for better caching
COPY requirements.txt .

# Install Python dependencies including development packages
RUN pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir debugpy ipython

# Create necessary directories
RUN mkdir -p /app/data /app/logs /app/keys

# Health check (less strict for development)
HEALTHCHECK --interval=60s --timeout=15s --start-period=120s --retries=2 \
    CMD curl -f http://localhost:8080/health || exit 1

# Expose ports
EXPOSE 8080 5678

# Default command with debug support
CMD ["python", "-m", "debugpy", "--listen", "0.0.0.0:5678", "--wait-for-client", "-m", "v4.src.bot.discord_client"]